<style>
* { margin:0; padding:0; box-sizing:border-box; }
:root {
  --black:#060606; --white:#F0EBE1; --orange:#E8520A;
  --dim:#0F0F0F; --silver:#5A5A5A; --txt:#A8A8A8;
}
::selection { background:var(--orange); color:var(--white); }
html { scroll-behavior:smooth; }
body { background:var(--black); color:var(--white); font-family:'Space Grotesk',sans-serif; overflow-x:hidden; }
::-webkit-scrollbar { width:3px; }
::-webkit-scrollbar-track { background:var(--black); }
::-webkit-scrollbar-thumb { background:var(--orange); }

nav {
  position:fixed; top:0; left:0; right:0; z-index:200;
  display:flex; align-items:center; justify-content:space-between;
  padding:0 2.5rem; height:56px;
  border-bottom:1px solid rgba(255,255,255,.06);
  background:rgba(6,6,6,.93); backdrop-filter:blur(10px);
}
.nav-logo { font-family:'Bebas Neue',sans-serif; font-size:1.25rem; letter-spacing:.22em; color:var(--white); }
.nav-right { display:flex; align-items:center; gap:2rem; }
.nav-link { font-size:.7rem; letter-spacing:.12em; text-transform:uppercase; color:var(--silver); border:none; background:none; font-family:'Space Grotesk',sans-serif; cursor:pointer; transition:color .2s; }
.nav-link:hover { color:var(--white); }
.nav-link.active { color:var(--orange); }
.live-dot { display:flex; align-items:center; gap:.4rem; font-size:.62rem; letter-spacing:.1em; text-transform:uppercase; color:var(--silver); }
.dot { width:6px; height:6px; background:var(--orange); border-radius:50%; animation:blink 1.4s ease-in-out infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.2} }

.page { display:none; min-height:100vh; padding-top:56px; }
.page.active { display:block; }

/* TICKER */
.ticker-bar { background:var(--orange); padding:.5rem 0; overflow:hidden; white-space:nowrap; position:relative; z-index:50; transition:filter .5s; }
.ticker-bar.glitch { filter:blur(8px) contrast(2); }
.ticker-track { display:inline-flex; white-space:nowrap; will-change:transform; }
.ticker-track span { font-family:'Bebas Neue',sans-serif; font-size:.9rem; letter-spacing:.25em; color:var(--black); padding:0 2rem; flex-shrink:0; }

/* HERO */
.hero { display:grid; grid-template-columns:1fr 1fr; min-height:calc(100vh - 56px - 36px); }
.hero-left { padding:4.5rem 3rem 4rem 3.5rem; display:flex; flex-direction:column; justify-content:space-between; border-right:1px solid rgba(255,255,255,.06); position:relative; overflow:hidden; }
.hero-tag { display:inline-flex; align-items:center; gap:.6rem; font-size:.62rem; letter-spacing:.2em; text-transform:uppercase; color:var(--orange); margin-bottom:2.5rem; }
.hero-tag::before { content:''; width:20px; height:1px; background:var(--orange); }
.hero-title { font-family:'Bebas Neue',sans-serif; font-size:clamp(5rem,11vw,10.5rem); line-height:.88; letter-spacing:.01em; }
.hero-title .outline { display:block; color:transparent; -webkit-text-stroke:1.5px rgba(240,235,225,.3); }
.hero-title .solid   { display:block; color:var(--white); }
.hero-title .accent  { display:block; color:var(--orange); }

.hero-desc { font-size:.85rem; line-height:1.75; color:var(--txt); max-width:360px; margin-top:2.5rem; opacity:0; transition:opacity .8s ease .3s; pointer-events:none; }
.hero-desc.revealed { opacity:1; pointer-events:auto; }

.play-banner { position:absolute; left:3.5rem; right:3rem; background:var(--orange); padding:.65rem 1.2rem; font-family:'Bebas Neue',sans-serif; font-size:1.05rem; letter-spacing:.2em; color:var(--black); opacity:0; pointer-events:none; transition:opacity .35s; animation:bannerPulse 2s ease-in-out infinite; top:0; }
.play-banner.visible { opacity:1; }
@keyframes bannerPulse { 0%,100%{opacity:1} 50%{opacity:.65} }

.fall-banner { position:absolute; inset:0; background:var(--orange); display:flex; align-items:center; padding-left:2rem; z-index:8; pointer-events:none; transform:translateY(-110%); }
.fall-banner.active { animation:fallDown 1.4s cubic-bezier(.4,0,.2,1) forwards; }
@keyframes fallDown { 0%{transform:translateY(-110%)} 45%{transform:translateY(0)} 100%{transform:translateY(110%)} }
.fall-banner span { font-family:'Bebas Neue',sans-serif; font-size:2rem; letter-spacing:.2em; color:var(--black); }

.hero-bottom { margin-top:4rem; display:flex; align-items:center; gap:2rem; flex-wrap:wrap; position:relative; z-index:2; }
.enter-btn { display:inline-flex; align-items:center; gap:.8rem; background:var(--orange); border:none; padding:.9rem 2rem; font-family:'Bebas Neue',sans-serif; font-size:1.1rem; letter-spacing:.18em; color:var(--white); cursor:pointer; transition:opacity .2s; }
.enter-btn:hover { opacity:.85; }
.enter-btn:disabled { opacity:.35; cursor:default; }
.hero-stat { display:flex; flex-direction:column; gap:.2rem; }
.hs-val { font-family:'Bebas Neue',sans-serif; font-size:2rem; letter-spacing:.06em; line-height:1; }
.hs-label { font-size:.58rem; letter-spacing:.18em; text-transform:uppercase; color:var(--silver); }

.hero-right { background:var(--dim); position:relative; overflow:hidden; display:flex; align-items:center; justify-content:center; min-height:400px; }
.court { position:absolute; inset:0; pointer-events:none; }
.court-arc { position:absolute; bottom:-60px; left:50%; transform:translateX(-50%); width:340px; height:340px; border:1px solid rgba(255,255,255,.06); border-radius:50%; }
.court-lane { position:absolute; bottom:0; left:50%; transform:translateX(-50%); width:130px; height:55%; border:1px solid rgba(255,255,255,.05); border-bottom:none; }
.court-hoop { position:absolute; bottom:55%; left:50%; transform:translateX(-50%); width:36px; height:36px; border:1.5px solid rgba(232,82,10,.4); border-radius:50%; }
.court-center { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:80px; height:80px; border:1px solid rgba(255,255,255,.04); border-radius:50%; }
.hero-bigN { font-family:'Bebas Neue',sans-serif; font-size:clamp(10rem,22vw,20rem); color:transparent; -webkit-text-stroke:1px rgba(255,255,255,.045); line-height:1; user-select:none; position:relative; z-index:1; }
.eq-bars { position:absolute; bottom:0; left:0; right:0; display:flex; align-items:flex-end; gap:2px; height:70px; padding:0 1.5rem; z-index:2; }
.eq-bar { flex:1; background:var(--orange); border-radius:1px 1px 0 0; opacity:.55; animation:eqPulse 1.6s ease-in-out infinite; }
@keyframes eqPulse { 0%,100%{transform:scaleY(.15);opacity:.3} 50%{transform:scaleY(1);opacity:.65} }
.score-overlay { position:absolute; top:2rem; left:2rem; z-index:3; display:flex; flex-direction:column; gap:.3rem; }
.score-line { font-family:'Bebas Neue',sans-serif; font-size:.75rem; letter-spacing:.22em; color:rgba(255,255,255,.15); text-transform:uppercase; }

#gameCanvas { position:absolute; top:0; left:0; width:100%; height:100%; z-index:10; display:none; touch-action:none; cursor:crosshair; }

/* JOYSTICK */
#joyWrap { position:absolute; bottom:2.5rem; left:50%; transform:translateX(-50%); z-index:20; display:none; flex-direction:column; align-items:center; gap:.5rem; }
#joyBase { width:100px; height:100px; border-radius:50%; border:2px solid rgba(232,82,10,.3); background:rgba(232,82,10,.06); position:relative; cursor:pointer; user-select:none; }
#joyKnob { position:absolute; width:40px; height:40px; border-radius:50%; background:var(--orange); top:50%; left:50%; transform:translate(-50%,-50%); box-shadow:0 0 16px rgba(232,82,10,.5); transition:box-shadow .1s; pointer-events:none; }
#joyLabel { font-family:'Bebas Neue',sans-serif; font-size:.6rem; letter-spacing:.22em; color:rgba(255,255,255,.2); text-transform:uppercase; }
#shootBtn { background:var(--orange); border:none; padding:.5rem 1.5rem; font-family:'Bebas Neue',sans-serif; font-size:.95rem; letter-spacing:.18em; color:var(--white); cursor:pointer; opacity:.0; transition:opacity .2s, transform .1s; border-radius:2px; display:none; }
#shootBtn.ready { opacity:1; }
#shootBtn:active { transform:scale(.95); }

.game-hud { position:absolute; top:1rem; right:1rem; z-index:15; display:none; flex-direction:column; align-items:flex-end; gap:.3rem; pointer-events:none; }
.hud-score { font-family:'Bebas Neue',sans-serif; font-size:3rem; letter-spacing:.08em; color:var(--orange); line-height:1; }
.hud-sub { font-size:.52rem; letter-spacing:.22em; text-transform:uppercase; color:var(--silver); }
.hud-pips { display:flex; gap:.5rem; margin-top:.3rem; }
.pip { width:12px; height:12px; border-radius:50%; background:rgba(255,255,255,.1); transition:background .2s; }
.pip.lit { background:var(--orange); }

.aim-hint { position:absolute; bottom:8rem; left:0; right:0; z-index:15; text-align:center; pointer-events:none; font-family:'Bebas Neue',sans-serif; font-size:.68rem; letter-spacing:.2em; color:rgba(255,255,255,.28); display:none; animation:hintFade 4s ease forwards; }
@keyframes hintFade { 0%{opacity:1} 75%{opacity:.3} 100%{opacity:0} }

.celebrate-overlay { position:absolute; inset:0; z-index:20; background:rgba(6,6,6,.97); display:none; flex-direction:column; align-items:center; justify-content:center; gap:1.2rem; text-align:center; padding:2rem; }
.celebrate-overlay.show { display:flex; animation:celebIn .9s ease; }
@keyframes celebIn { from{opacity:0;transform:scale(.96)} to{opacity:1;transform:scale(1)} }
.cel-title { font-family:'Bebas Neue',sans-serif; font-size:clamp(1.8rem,4.5vw,3.5rem); line-height:1.05; letter-spacing:.03em; color:var(--white); }
.cel-title span { color:var(--orange); }
.cel-sub { font-size:.65rem; letter-spacing:.2em; text-transform:uppercase; color:var(--silver); }
.cel-emoji { font-size:1.8rem; }

footer { border-top:1px solid rgba(255,255,255,.05); padding:1.4rem 3.5rem; display:flex; justify-content:space-between; align-items:center; }
footer span { font-size:.55rem; letter-spacing:.2em; text-transform:uppercase; color:rgba(255,255,255,.14); }
footer .flogo { font-family:'Bebas Neue',sans-serif; font-size:.95rem; letter-spacing:.2em; color:rgba(255,255,255,.07); }

/* TEXT PAGE */
.text-page-wrap { display:grid; grid-template-columns:220px 1fr; min-height:calc(100vh - 56px); }
.text-sidebar { border-right:1px solid rgba(255,255,255,.06); padding:3.5rem 1.8rem; display:flex; flex-direction:column; justify-content:space-between; position:sticky; top:56px; height:calc(100vh - 56px); overflow:hidden; }
.ts-top { display:flex; flex-direction:column; gap:1.5rem; }
.ts-num { font-family:'Bebas Neue',sans-serif; font-size:7rem; line-height:1; color:transparent; -webkit-text-stroke:1px rgba(255,255,255,.08); }
.ts-label { font-size:.55rem; letter-spacing:.32em; text-transform:uppercase; color:var(--orange); }
.ts-title { font-family:'Bebas Neue',sans-serif; font-size:1.9rem; line-height:1; letter-spacing:.04em; color:var(--white); }
.ts-note { font-size:.62rem; line-height:1.75; color:var(--silver); border-left:2px solid var(--orange); padding-left:.8rem; }
.sidebar-eq { display:flex; align-items:flex-end; gap:2px; height:28px; margin-top:1.2rem; }
.seq-bar { flex:1; background:var(--orange); border-radius:1px; opacity:.35; }
.ts-bottom { font-size:.44rem; letter-spacing:.2em; text-transform:uppercase; color:rgba(255,255,255,.08); }
.text-main { padding:4.5rem 4rem 5rem; }
.tm-eyebrow { display:flex; align-items:center; gap:.8rem; font-size:.6rem; letter-spacing:.28em; text-transform:uppercase; color:var(--orange); margin-bottom:3rem; }
.tm-eyebrow::before { content:''; width:20px; height:1px; background:var(--orange); }
.raw-text { font-family:'Space Grotesk',sans-serif; font-size:.95rem; font-weight:300; line-height:2.1; color:#888; max-width:700px; }
.raw-text::first-letter { font-family:'Bebas Neue',sans-serif; float:left; font-size:6rem; line-height:.8; padding-right:.1em; color:var(--orange); margin-top:.05em; }
.h-w { color:var(--white); font-weight:500; }
.h-o { color:var(--orange); }
.h-i { font-style:italic; color:#C0B8AE; }
</style>
</head>
