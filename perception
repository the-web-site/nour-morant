window.addEventListener('load', positionBanner);
window.addEventListener('resize', positionBanner);

/* ══════════════════════════════
   GAME
══════════════════════════════ */
const canvas = document.getElementById('gameCanvas');
const ctx    = canvas.getContext('2d');

/* state */
let G_active  = false;
let G_over    = false;
let G_scored  = 0;
let G_ball    = null;
let G_flash   = 0;
let G_shake   = 0;
let G_raf     = null;
let G_hoop    = {};
let G_player  = {};

/* joystick state */
const JOY_MAX = 35;   /* max knob travel in px */
let joy = { dragging:false, dx:0, dy:0 };

const GRAVITY = 0.22;

/* canvas → logical coords */
function canvasXY(e){
  const r = canvas.getBoundingClientRect();
  const sx = canvas.width  / r.width;
  const sy = canvas.height / r.height;
  const src = e.touches ? e.touches[0] : (e.changedTouches ? e.changedTouches[0] : e);
  return { x:(src.clientX-r.left)*sx, y:(src.clientY-r.top)*sy };
}

function setupGame(){
  const W=canvas.width, H=canvas.height;
  G_hoop   = { x:W/2, y:H*0.18, r:28 };
  G_player = { x:W/2, y:H*0.76 };
}

function resizeCanvas(){
  const r = canvas.parentElement.getBoundingClientRect();
  canvas.width  = r.width;
  canvas.height = r.height;
  setupGame();
}

function spawnBall(){
  G_ball = { x:G_player.x, y:G_player.y-30, vx:0, vy:0, r:11, live:false, trail:[] };
}

/* ─── JOYSTICK interactions ─── */
const joyBase  = document.getElementById('joyBase');
const joyKnob  = document.getElementById('joyKnob');
const shootBtn = document.getElementById('shootBtn');

function joyCoords(e){
  const r   = joyBase.getBoundingClientRect();
  const src = e.touches ? e.touches[0] : (e.changedTouches ? e.changedTouches[0] : e);
  return { x: src.clientX - r.left - r.width/2,
           y: src.clientY - r.top  - r.height/2 };
}

function clampJoy(dx, dy){
  const d = Math.sqrt(dx*dx+dy*dy);
  if(d > JOY_MAX){ const s=JOY_MAX/d; return {dx:dx*s, dy:dy*s}; }
  return {dx, dy};
}

function updateKnob(dx, dy){
  joyKnob.style.transform = `translate(calc(-50% + ${dx}px), calc(-50% + ${dy}px))`;
}

joyBase.addEventListener('mousedown', e=>{ joy.dragging=true; onJoyMove(e); });
window.addEventListener('mousemove',  e=>{ if(joy.dragging) onJoyMove(e); });
window.addEventListener('mouseup',    e=>{ if(joy.dragging){ joy.dragging=false; releaseJoy(); } });

joyBase.addEventListener('touchstart', e=>{ e.preventDefault(); joy.dragging=true; onJoyMove(e.touches[0]); },{passive:false});
joyBase.addEventListener('touchmove',  e=>{ e.preventDefault(); onJoyMove(e.touches[0]); },{passive:false});
joyBase.addEventListener('touchend',   e=>{ e.preventDefault(); joy.dragging=false; releaseJoy(); },{passive:false});

function onJoyMove(e){
  if(!G_active || !G_ball || G_ball.live) return;
  const raw = joyCoords(e);
  const c   = clampJoy(raw.x, raw.y);
  joy.dx = c.dx; joy.dy = c.dy;
  updateKnob(c.dx, c.dy);
  shootBtn.className = Math.sqrt(c.dx*c.dx+c.dy*c.dy) > 8 ? 'ready' : '';
}

function releaseJoy(){
  /* release = auto-shoot (like a slingshot) */
  if(G_active && G_ball && !G_ball.live){
    const d = Math.sqrt(joy.dx*joy.dx + joy.dy*joy.dy);
    if(d > 8) fireFromJoy();
  }
  joy.dx=0; joy.dy=0;
  updateKnob(0,0);
  shootBtn.className='';
}

function fireFromJoy(){
  if(!G_active || !G_ball || G_ball.live) return;

  /* invert direction: pulling down-right shoots up-left toward hoop */
  const rawDx = -joy.dx;
  const rawDy = -joy.dy;
  const d = Math.sqrt(rawDx*rawDx + rawDy*rawDy);
  if(d < 5) return;

  /* normalized */
  const nx = rawDx / d;
  const ny = rawDy / d;

  /* power proportional to how far the joystick was pulled */
  const t   = Math.min(d / JOY_MAX, 1);
  const spd = 6 + t * 9;              /* range 6–15 */

  G_ball.vx = nx * spd;
  G_ball.vy = ny * spd;
  G_ball.live = true;

  joy.dx=0; joy.dy=0;
  updateKnob(0,0);
  shootBtn.className='';
}

/* ─── game loop ─── */
function gameLoop(){
  if(!G_active) return;
  update();
  draw();
  G_raf = requestAnimationFrame(gameLoop);
}

function update(){
  if(!G_ball) return;
  if(G_flash>0) G_flash--;
  if(G_shake>0) G_shake--;
  if(!G_ball.live) return;

  G_ball.vy += GRAVITY;
  G_ball.x  += G_ball.vx;
  G_ball.y  += G_ball.vy;
  G_ball.vx *= 0.999;

  /* trail */
  G_ball.trail.push({x:G_ball.x, y:G_ball.y});
  if(G_ball.trail.length>22) G_ball.trail.shift();

  /* ── GENEROUS score window ──
     Ball scores when horizontally inside the rim AND
     passing through the hoop plane downward.
     Window is 1.5× the rim radius for leniency.     */
  const hoopWindow = G_hoop.r * 1.5;
  const inX = Math.abs(G_ball.x - G_hoop.x) < hoopWindow;
  const inY = G_ball.y > G_hoop.y - 6 && G_ball.y < G_hoop.y + 28;

  if(G_ball.vy > 0 && inX && inY){ bucket(); return; }

  /* REALISTIC OPEN RIM COLLISION */

const dx = G_ball.x - G_hoop.x;
const dy = G_ball.y - G_hoop.y;
const dist = Math.sqrt(dx*dx + dy*dy);

/* left rim */
const leftRimX = G_hoop.x - G_hoop.r;
const rightRimX = G_hoop.x + G_hoop.r;
const rimY = G_hoop.y;

/* collide ONLY with left/right metal parts */
const hitLeft =
  Math.hypot(G_ball.x - leftRimX, G_ball.y - rimY)
  < G_ball.r + 4;

const hitRight =
  Math.hypot(G_ball.x - rightRimX, G_ball.y - rimY)
  < G_ball.r + 4;

if(hitLeft || hitRight){

  /* bounce */
  G_ball.vy *= -0.72;

  if(hitLeft){
    G_ball.vx -= 1.2;
  } else {
    G_ball.vx += 1.2;
  }

  G_shake = 5;
}

  /* out of bounds */
  const W=canvas.width, H=canvas.height;
  if(G_ball.y>H+50 || G_ball.x<-60 || G_ball.x>W+60){
    G_shake=12;
    setTimeout(spawnBall,400);
    G_ball=null;
  }
}

function bucket(){
  G_scored++;
  G_flash=24;
  document.getElementById('hudScore').textContent=G_scored;
  document.getElementById('pip'+(G_scored-1)).classList.add('lit');
  if(G_scored>=3){ G_over=true; G_active=false; cancelAnimationFrame(G_raf); setTimeout(triggerVictory,500); return; }
  setTimeout(spawnBall,600);
  G_ball=null;
}

/* ─── draw ─── */
function draw(){
  const W=canvas.width, H=canvas.height;
  ctx.clearRect(0,0,W,H);

  /* court faint lines */
  ctx.save();
  ctx.strokeStyle='rgba(255,255,255,.035)'; ctx.lineWidth=1;
  ctx.beginPath(); ctx.arc(G_hoop.x,G_hoop.y,H*.32,0,Math.PI*2); ctx.stroke();
  ctx.strokeRect(G_hoop.x-60,G_hoop.y-10,120,H*.45);
  ctx.restore();

  /* ghost N */
  ctx.save();
  ctx.font=`${Math.min(W,H)*.54}px 'Bebas Neue',sans-serif`;
  ctx.strokeStyle='rgba(255,255,255,.035)'; ctx.lineWidth=1;
  ctx.textAlign='center'; ctx.textBaseline='middle';
  ctx.strokeText('N',W/2,H/2);
  ctx.restore();

  /* ─ HOOP ─ */
  ctx.save();
  /* back rim shadow */
  ctx.beginPath(); ctx.arc(G_hoop.x,G_hoop.y+2,G_hoop.r+1,0,Math.PI*2);
  ctx.strokeStyle='rgba(0,0,0,.3)'; ctx.lineWidth=6; ctx.stroke();
  /* main rim */
  const rimColor = G_flash>0 ? `rgba(232,82,10,${.55+.45*(G_flash/24)})` : 'rgba(232,82,10,.55)';
  ctx.beginPath(); ctx.arc(G_hoop.x,G_hoop.y,G_hoop.r,0,Math.PI*2);
  ctx.strokeStyle=rimColor; ctx.lineWidth=4; ctx.stroke();
  /* inner highlight */
  ctx.beginPath(); ctx.arc(G_hoop.x,G_hoop.y,G_hoop.r-1,0,Math.PI*2);
  ctx.strokeStyle='rgba(255,160,60,.18)'; ctx.lineWidth=2; ctx.stroke();
  /* net lines (simple) */
  ctx.strokeStyle='rgba(255,255,255,.12)'; ctx.lineWidth=1;
  for(let i=0;i<6;i++){
    const a=(i/6)*Math.PI*2;
    const rx=G_hoop.x+Math.cos(a)*G_hoop.r, ry=G_hoop.y+Math.sin(a)*G_hoop.r;
    ctx.beginPath(); ctx.moveTo(rx,ry); ctx.lineTo(G_hoop.x,G_hoop.y+G_hoop.r*.6); ctx.stroke();
  }
  /* backboard */
  ctx.strokeStyle='rgba(255,255,255,.2)'; ctx.lineWidth=2.5;
  ctx.beginPath(); ctx.moveTo(G_hoop.x-46,G_hoop.y-34); ctx.lineTo(G_hoop.x+46,G_hoop.y-34); ctx.stroke();
  ctx.restore();

  /* BUCKET text */
  if(G_flash>14){
    const a=(G_flash-14)/10;
    ctx.save(); ctx.font="bold 1rem 'Bebas Neue',sans-serif";
    ctx.fillStyle=`rgba(232,82,10,${a})`; ctx.textAlign='center';
    ctx.fillText('BUCKET!',G_hoop.x,G_hoop.y-55);
    ctx.restore();
  }

  /* AIM GUIDE from joystick */
  if(joy.dragging && G_ball && !G_ball.live && (Math.abs(joy.dx)>5||Math.abs(joy.dy)>5)){
    const rawDx=-joy.dx, rawDy=-joy.dy;
    const d=Math.sqrt(rawDx*rawDx+rawDy*rawDy);
    if(d>5){
      const nx=rawDx/d, ny=rawDy/d;
      const t=Math.min(d/JOY_MAX,1);
      const spd=6+t*9;
      ctx.save();
      ctx.setLineDash([5,8]); ctx.strokeStyle='rgba(232,82,10,.75)'; ctx.lineWidth=2.5;
      ctx.beginPath(); ctx.moveTo(G_ball.x,G_ball.y);
      let px=G_ball.x,py=G_ball.y,pvx=nx*spd,pvy=ny*spd;
      for(let s=0;s<90;s++){
        pvy+=GRAVITY; px+=pvx; py+=pvy; pvx*=.999;
        ctx.lineTo(px,py);
        if(py>H) break;
      }
      ctx.stroke(); ctx.restore();
    }
  }

  /* BALL TRAIL */
  if(G_ball&&G_ball.live&&G_ball.trail.length){
    G_ball.trail.forEach((p,i)=>{
      const a=(i/G_ball.trail.length)*.3;
      const r=G_ball.r*(i/G_ball.trail.length)*.55;
      ctx.beginPath(); ctx.arc(p.x,p.y,Math.max(r,1),0,Math.PI*2);
      ctx.fillStyle=`rgba(232,82,10,${a})`; ctx.fill();
    });
  }

  /* BALL */
  if(G_ball){
    const sx=G_shake>0?(Math.random()-.5)*5*(G_shake/12):0;
    ctx.save(); ctx.translate(sx,0);
    const grd=ctx.createRadialGradient(G_ball.x-3,G_ball.y-3,1,G_ball.x,G_ball.y,G_ball.r);
    grd.addColorStop(0,'#FF9A20'); grd.addColorStop(.5,'#E8520A'); grd.addColorStop(1,'#6E1800');
    ctx.beginPath(); ctx.arc(G_ball.x,G_ball.y,G_ball.r,0,Math.PI*2); ctx.fillStyle=grd; ctx.fill();
    ctx.strokeStyle='rgba(0,0,0,.80)'; ctx.lineWidth=.8; ctx.stroke();
    ctx.strokeStyle='rgba(0,0,0,.3)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(G_ball.x-G_ball.r,G_ball.y); ctx.lineTo(G_ball.x+G_ball.r,G_ball.y); ctx.stroke();
    ctx.beginPath(); ctx.arc(G_ball.x,G_ball.y,G_ball.r,-.3,Math.PI+.3);
    ctx.strokeStyle='rgba(0,0,0,.2)'; ctx.lineWidth=.7; ctx.stroke();
    ctx.restore();
  }

  /* PLAYER */
  drawJay(G_player.x, G_player.y);
}

/* ─ Jay Morant character ─ */
function drawJay(x, y){
  ctx.save();
  const t   = Date.now();
  const bob = Math.sin(t*.003)*2;
  const by  = bob;

  /* shadow */
  ctx.beginPath(); ctx.ellipse(x,y+26+by,20,5,0,0,Math.PI*2);
  ctx.fillStyle='rgba(0,0,0,.3)'; ctx.fill();

  /* ── LEGS ── */
  ctx.strokeStyle='#111'; ctx.lineWidth=6; ctx.lineCap='round';
  /* left thigh */
  ctx.beginPath(); ctx.moveTo(x-5,y+10+by); ctx.lineTo(x-8,y+20+by); ctx.stroke();
  /* left shin */
  ctx.beginPath(); ctx.moveTo(x-8,y+20+by); ctx.lineTo(x-11,y+28+by); ctx.stroke();
  /* right thigh */
  ctx.beginPath(); ctx.moveTo(x+5,y+10+by); ctx.lineTo(x+8,y+20+by); ctx.stroke();
  /* right shin */
  ctx.beginPath(); ctx.moveTo(x+8,y+20+by); ctx.lineTo(x+12,y+28+by); ctx.stroke();

  /* socks (white strip) */
  ctx.strokeStyle='rgba(255,255,255,.7)'; ctx.lineWidth=3;
  ctx.beginPath(); ctx.moveTo(x-11,y+24+by); ctx.lineTo(x-11,y+27+by); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(x+12,y+24+by); ctx.lineTo(x+12,y+27+by); ctx.stroke();

  /* shoes — Nike Jordan 1 silhouette */
  ctx.fillStyle='#111';
  /* left shoe */
  ctx.beginPath();
  ctx.moveTo(x-16,y+29+by); ctx.lineTo(x-4,y+29+by);
  ctx.lineTo(x-4,y+26+by); ctx.lineTo(x-11,y+26+by);
  ctx.closePath(); ctx.fill();
  /* right shoe */
  ctx.beginPath();
  ctx.moveTo(x+4,y+29+by); ctx.lineTo(x+18,y+29+by);
  ctx.lineTo(x+18,y+26+by); ctx.lineTo(x+12,y+26+by);
  ctx.closePath(); ctx.fill();
  /* orange swoosh stripe */
  ctx.strokeStyle='#E8520A'; ctx.lineWidth=1.5;
  ctx.beginPath(); ctx.moveTo(x-14,y+27.5+by); ctx.bezierCurveTo(x-10,y+26+by,x-7,y+27+by,x-5,y+27.5+by); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(x+6,y+27.5+by);  ctx.bezierCurveTo(x+10,y+26+by,x+14,y+27+by,x+16,y+27.5+by); ctx.stroke();

  /* ── SHORTS ── */
  ctx.fillStyle='#0A0A1A'; /* Memphis navy */
  ctx.beginPath();
  ctx.roundRect(x-13,y+8+by,26,14,3);
  ctx.fill();
  /* shorts stripe */
  ctx.fillStyle='#E8520A';
  ctx.fillRect(x-13,y+8+by,3,14);
  ctx.fillRect(x+10,y+8+by,3,14);

  /* ── JERSEY ── */
  const jg=ctx.createLinearGradient(x,y-14+by,x,y+10+by);
  jg.addColorStop(0,'#1B4FDB'); /* Memphis Grizzlies navy/blue */
  jg.addColorStop(1,'#0A2080');
  ctx.beginPath(); ctx.roundRect(x-12,y-14+by,24,24,4);
  ctx.fillStyle=jg; ctx.fill();
  /* jersey side stripes */
  ctx.fillStyle='#E8520A';
  ctx.fillRect(x-12,y-14+by,3,24);
  ctx.fillRect(x+9,y-14+by,3,24);
  /* jersey number 12 */
  ctx.font="bold 9px 'Bebas Neue',sans-serif";
  ctx.fillStyle='rgba(255,255,255,.9)';
  ctx.textAlign='center'; ctx.textBaseline='middle';
  ctx.fillText('12',x,y-3+by);

  /* ── ARMS ── */
  ctx.strokeStyle='#5C3317'; ctx.lineWidth=5; ctx.lineCap='round';
  const holding = joy.dragging && G_ball && !G_ball.live;
  if(holding){
    /* arms raised for shot */
    ctx.beginPath(); ctx.moveTo(x-11,y-8+by); ctx.lineTo(x-20,y-22+by); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x+11,y-8+by); ctx.lineTo(x+20,y-22+by); ctx.stroke();
    /* wristbands */
    ctx.strokeStyle='#E8520A'; ctx.lineWidth=3;
    ctx.beginPath(); ctx.moveTo(x-19,y-20+by); ctx.lineTo(x-17,y-24+by); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x+17,y-20+by); ctx.lineTo(x+19,y-24+by); ctx.stroke();
  } else {
    /* relaxed arms */
    ctx.beginPath(); ctx.moveTo(x-11,y-8+by); ctx.lineTo(x-17,y+4+by); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x+11,y-8+by); ctx.lineTo(x+17,y+4+by); ctx.stroke();
    /* wristbands */
    ctx.strokeStyle='#E8520A'; ctx.lineWidth=3;
    ctx.beginPath(); ctx.moveTo(x-17,y+2+by); ctx.lineTo(x-15,y+6+by); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(x+15,y+2+by); ctx.lineTo(x+17,y+6+by); ctx.stroke();
  }

  /* ── NECK ── */
  ctx.fillStyle='#5C3317';
  ctx.beginPath(); ctx.roundRect(x-4,y-20+by,8,9,2); ctx.fill();

  /* ── HEAD ── */
  /* head shadow */
  ctx.beginPath(); ctx.ellipse(x+1,y-25+by,12,14,0,0,Math.PI*2);
  ctx.fillStyle='rgba(0,0,0,.2)'; ctx.fill();
  /* main head — oval (Jay's face shape) */
  ctx.beginPath(); ctx.ellipse(x,y-26+by,11,13,0,0,Math.PI*2);
  ctx.fillStyle='#6B3D1E'; ctx.fill();
  /* face highlight */
  ctx.beginPath(); ctx.ellipse(x-3,y-30+by,4,5,-.3,0,Math.PI*2);
  ctx.fillStyle='rgba(255,255,255,.08)'; ctx.fill();

  /* ── HAIR — Jay's signature locs ── */
  const locColors = ['#1a0d06','#2b1608','#1a0d06','#2b1608','#1a0d06','#241006'];
  /* back locs (drawn first, behind head) */
  for(let i=0;i<5;i++){
    const a = -0.6 + i*0.3;
    ctx.beginPath();
    ctx.moveTo(x + Math.cos(a)*9, y-36+by);
    ctx.quadraticCurveTo(
      x + Math.cos(a)*14, y-44+by,
      x + Math.cos(a)*12 + Math.sin(i)*3, y-38+by
    );
    ctx.strokeStyle=locColors[i%locColors.length]; ctx.lineWidth=3; ctx.stroke();
  }
  /* front locs falling forward */
  for(let i=0;i<4;i++){
    const startX = x - 8 + i*5;
    ctx.beginPath();
    ctx.moveTo(startX, y-36+by);
    ctx.quadraticCurveTo(startX-2, y-42+by, startX+1, y-40+by);
    ctx.strokeStyle=locColors[i%locColors.length]; ctx.lineWidth=2.5; ctx.stroke();
  }
  /* loc tips (slightly lighter) */
  ctx.strokeStyle='#3d1c0a'; ctx.lineWidth=1.5;
  ctx.beginPath(); ctx.moveTo(x-7,y-42+by); ctx.lineTo(x-9,y-45+by); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(x-2,y-43+by); ctx.lineTo(x-4,y-46+by); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(x+3, y-43+by); ctx.lineTo(x+1, y-46+by); ctx.stroke();

  /* headband (Grizzlies colors) */
  ctx.strokeStyle='#E8520A'; ctx.lineWidth=4;
  ctx.beginPath(); ctx.arc(x,y-26+by,11,Math.PI*.65,Math.PI*.35,false); ctx.stroke();
  ctx.strokeStyle='#1B4FDB'; ctx.lineWidth=2;
  ctx.beginPath(); ctx.arc(x,y-26+by,11,Math.PI*.65,Math.PI*.35,false); ctx.stroke();

  /* ── FACE ── */
  /* eyebrows — slight frown / intensity */
  ctx.strokeStyle='#2b1608'; ctx.lineWidth=1.8;
  ctx.beginPath(); ctx.moveTo(x-5,y-29+by); ctx.lineTo(x-2,y-30+by); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(x+2,y-30+by); ctx.lineTo(x+5,y-29+by); ctx.stroke();
  /* eyes — almond shape */
  ctx.fillStyle='#fff';
  ctx.beginPath(); ctx.ellipse(x-4,y-26+by,2.5,1.8,-.15,0,Math.PI*2); ctx.fill();
  ctx.beginPath(); ctx.ellipse(x+4,y-26+by,2.5,1.8, .15,0,Math.PI*2); ctx.fill();
  ctx.fillStyle='#1a0800';
  ctx.beginPath(); ctx.arc(x-4,y-26+by,1.2,0,Math.PI*2); ctx.fill();
  ctx.beginPath(); ctx.arc(x+4,y-26+by,1.2,0,Math.PI*2); ctx.fill();
  /* eye shine */
  ctx.fillStyle='rgba(255,255,255,.7)';
  ctx.beginPath(); ctx.arc(x-3.2,y-26.5+by,.6,0,Math.PI*2); ctx.fill();
  ctx.beginPath(); ctx.arc(x+4.8,y-26.5+by,.6,0,Math.PI*2); ctx.fill();
  /* nose */
  ctx.strokeStyle='rgba(0,0,0,.35)'; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(x-1,y-24+by); ctx.lineTo(x-2,y-21+by); ctx.lineTo(x+1,y-21+by); ctx.stroke();
  /* mouth — determined smirk */
  ctx.strokeStyle='rgba(0,0,0,.4)'; ctx.lineWidth=1.2;
  ctx.beginPath(); ctx.moveTo(x-3,y-18+by); ctx.quadraticCurveTo(x,y-17+by,x+3,y-18.5+by); ctx.stroke();

  ctx.restore();
}

/* ── START GAME ── */
function handleBtn(){
  if(!G_active && !G_over) startGame();
}

function startGame(){
  G_active=true; G_over=false; G_scored=0;
  document.getElementById('staticCourt').style.display='none';
  document.getElementById('scoreOverlay').style.display='none';
  document.getElementById('bigN').style.display='none';
  document.getElementById('eqBars').style.display='none';
  document.getElementById('celebrateOverlay').classList.remove('show');
  [0,1,2].forEach(i=>document.getElementById('pip'+i).classList.remove('lit'));

  canvas.style.display='block';
  document.getElementById('joyWrap').style.display='flex';
  document.getElementById('gameHud').style.display='flex';
  document.getElementById('hudScore').textContent='0';
  document.getElementById('tickerBar').classList.add('glitch');

  positionBanner();
  document.getElementById('playBanner').classList.add('visible');
  document.getElementById('mainBtn').disabled=true;

  resizeCanvas();
  window.addEventListener('resize', resizeCanvas);

  const hint=document.getElementById('aimHint');
  hint.style.display='block';
  hint.style.animation='none'; void hint.offsetWidth;
  hint.style.animation='hintFade 4s ease forwards';
  setTimeout(()=>{ hint.style.display='none'; },4000);

  spawnBall();
  gameLoop();
}

/* ── VICTORY ── */
function triggerVictory(){
  cancelAnimationFrame(G_raf);
  document.getElementById('celebrateOverlay').classList.add('show');
  document.getElementById('joyWrap').style.display='none';
  document.getElementById('tickerBar').classList.remove('glitch');
  document.getElementById('playBanner').classList.remove('visible');
  const fb=document.getElementById('fallBanner');
  fb.classList.add('active');
  setTimeout(()=>{ document.getElementById('heroDesc').classList.add('revealed'); },800);
  setTimeout(()=>{
    document.getElementById('celebrateOverlay').classList.remove('show');
    canvas.style.display='none';
    document.getElementById('gameHud').style.display='none';
    document.getElementById('staticCourt').style.display='block';
    document.getElementById('scoreOverlay').style.display='flex';
    document.getElementById('bigN').style.display='block';
    document.getElementById('eqBars').style.display='flex';
    fb.classList.remove('active');
    const btn=document.getElementById('mainBtn');
    btn.disabled=false; btn.innerHTML='Read it →';
    btn.onclick=()=>showPage('polished');
    window.removeEventListener('resize', resizeCanvas);
    G_active=false;
  },3800);
}
</script>
